<?xml version="1.0"?>
<sdf version="1.9">
  <model name="coordination_diffbot">
    <static>false</static>
    <pose>0 0 0.08 0 0 0</pose>

    <link name="base_link">
      <inertial>
        <mass>4.0</mass>
        <inertia>
          <ixx>0.08</ixx>
          <iyy>0.10</iyy>
          <izz>0.12</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <pose>0 0 0.12 0 0 0</pose>
        <geometry>
          <box>
            <size>0.45 0.32 0.16</size>
          </box>
        </geometry>
      </collision>
      <visual name="base_visual">
        <pose>0 0 0.12 0 0 0</pose>
        <geometry>
          <box>
            <size>0.45 0.32 0.16</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.38 0.85 1.0</ambient>
          <diffuse>0.1 0.38 0.85 1.0</diffuse>
        </material>
      </visual>
      <visual name="front_marker">
        <pose>0.24 0 0.16 0 0 0</pose>
        <geometry>
          <box>
            <size>0.04 0.24 0.035</size>
          </box>
        </geometry>
        <material>
          <ambient>0.95 0.78 0.18 1.0</ambient>
          <diffuse>0.95 0.78 0.18 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="left_wheel">
      <pose>0 0.19 0.08 1.57079632679 0 0</pose>
      <inertial>
        <mass>0.45</mass>
        <inertia>
          <ixx>0.001</ixx>
          <iyy>0.001</iyy>
          <izz>0.001</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.04 0.04 0.045 1.0</ambient>
          <diffuse>0.04 0.04 0.045 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="right_wheel">
      <pose>0 -0.19 0.08 1.57079632679 0 0</pose>
      <inertial>
        <mass>0.45</mass>
        <inertia>
          <ixx>0.001</ixx>
          <iyy>0.001</iyy>
          <izz>0.001</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <collision name="right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.04 0.04 0.045 1.0</ambient>
          <diffuse>0.04 0.04 0.045 1.0</diffuse>
        </material>
      </visual>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1.0e16</lower>
          <upper>1.0e16</upper>
        </limit>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1.0e16</lower>
          <upper>1.0e16</upper>
        </limit>
      </axis>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.38</wheel_separation>
      <wheel_radius>0.08</wheel_radius>
      <odom_publish_frequency>30</odom_publish_frequency>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <max_linear_velocity>0.8</max_linear_velocity>
      <max_angular_velocity>1.8</max_angular_velocity>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>3.0</max_angular_acceleration>
    </plugin>
  </model>
</sdf>

